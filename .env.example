# Required: app credentials from Feishu Developer Console
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: restrict the bot to a single chat. If unset, any chat that adds the bot can play.
ALLOWED_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Address the HTTP webhook server binds to.
BIND_ADDR=0.0.0.0:8080

# Optional: Verification Token from event subscription page. If set, webhook payloads are
# verified against this token. Leave unset to skip verification.
FEISHU_VERIFICATION_TOKEN=

# Optional: LLM-backed AI opponent. Set OPENAI_API_KEY to enable the [加入 AI]
# button on the lobby card. Anything OpenAI-compatible works.
#
# DeepSeek:  base=https://api.deepseek.com           model=deepseek-v4-flash
# Doubao:    base=https://ark.cn-beijing.volces.com/api/v3
#            model=doubao-seed-2-0-lite-260215
# OpenAI:    base=https://api.openai.com/v1          model=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# Path to the redb file holding persisted game state (chip stacks, lobby
# membership, etc.). Survives process restarts. For Docker, mount a volume
# at /data and set this to /data/arena.redb.
LARK_ARENA_DB_PATH=arena.redb

# Logging — env-filter target uses the crate name with hyphens replaced by
# underscores (Rust identifier rules), so it's `lark_arena` not `lark-arena`.
RUST_LOG=lark_arena=info,tower_http=info
